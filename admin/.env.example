# LiveDesk admin frontend — example env. Copy to `.env.local` for local dev.

# Backend API base URL.
# - Docker compose: http://localhost:8000
# - Laravel Herd:   http://livechat-api.test (or whatever you `herd link`-ed apps/api to)
VITE_API_URL=http://localhost:8000

# Reverb (websockets) — must match the backend's REVERB_* config.
VITE_REVERB_APP_KEY=local
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

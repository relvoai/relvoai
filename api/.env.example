APP_NAME="LiveChat"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://support.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=livechat
DB_USERNAME=benny
DB_PASSWORD=change-me

# Postgres must have the pgvector extension enabled for the AI SDK vector columns:
# psql -U $DB_USERNAME -d $DB_DATABASE -c "CREATE EXTENSION IF NOT EXISTS vector;"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="support@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CORS — comma-separated. Widget endpoints must accept any customer domain,
# so default to "*". For staff APIs behind a known admin UI, narrow this.
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_ORIGINS_PATTERNS=

# Reverb broadcasting
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=support.example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Rate limiting (requests per minute)
WIDGET_BOOTSTRAP_RATE_LIMIT=30
WIDGET_MESSAGE_RATE_LIMIT=60
WIDGET_RATING_RATE_LIMIT=10
LOGIN_RATE_LIMIT=10

# Attachments
ATTACHMENTS_DISK=public
ATTACHMENTS_MAX_KB=10240
ATTACHMENTS_ALLOWED_MIMES=jpg,jpeg,png,gif,webp,pdf,doc,docx,txt,csv,xls,xlsx,zip

# AI SDK — provider keys funded by the app (customers spend credits, not keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
# (see config/ai.php for full provider list)

AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
AI_DEFAULT_EMBEDDING_DIMENSIONS=1536
AI_DEFAULT_CHAT_MODEL=gpt-4o-mini
